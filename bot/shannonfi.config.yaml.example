# ─────────────────────────────────────────────────────────────────────────────
# Shannon's Demon — Bot Configuration
# ─────────────────────────────────────────────────────────────────────────────
# SETUP:
#   1. Copy this file:  cp shannonfi.config.yaml.example shannonfi.config.yaml
#   2. Fill in your Mercado Bitcoin API credentials.
#   3. Review the strategy parameters and tax compliance options.
#   4. NEVER commit shannonfi.config.yaml — it contains secrets.
#
# SECURITY: shannonfi.config.yaml is in .gitignore by default.
#           Keep it out of version control and CI logs.
# ─────────────────────────────────────────────────────────────────────────────

# ── Exchange Selection ────────────────────────────────────────────────────────
# Options: mercadobitcoin | binance
exchange: mercadobitcoin

# Trading pair symbol. The base asset is the non-BRL side (e.g. SOL, HYPE, BTC).
# Change to switch the bot to a different asset (e.g. HYPE-BRL).
symbol: SOL-BRL


# ── Mercado Bitcoin credentials ────────────────────────────────────────────────
# (Required only if exchange: mercadobitcoin)
# Obtain from: https://www.mercadobitcoin.com.br → Account → API → Create credential
# Required scopes: read (balances, orders), write (place orders)
# Tax law: Lei 9.250/1995 Art. 21 (domestic exchange)
#   - Monthly SELL proceeds ≤ R$35,000: exempt from capital gains tax
#   - Above threshold: DARF payment by last business day of the following month

mercadobitcoin:
  clientId: "your-client-id-here"
  clientSecret: "your-client-secret-here"
  # apiBaseUrl: https://api.mercadobitcoin.net/api/v4   # default — do not change


# ── Binance credentials ────────────────────────────────────────────────────────
# (Required only if exchange: binance)
# Obtain from: https://www.binance.com/account/api-management
# 1. Enable Spot & Margin Trading
# 2. Restrict to your IP address (highly recommended)
# 3. Do NOT enable withdrawals
# Note: Binance.com supports SOLBRL natively. Gains are always taxable (not eligible
#       for Lei 9.250 exemption).

# binance:
#   apiKey: "your-api-key-here"
#   apiSecret: "your-api-secret-here"
#   # apiBaseUrl: https://api.binance.com   # default — do not change


# ── Strategy parameters ────────────────────────────────────────────────────────

# Fixed rebalance threshold in basis points (1 bps = 0.01%).
# Used as fallback when useAdaptiveThreshold is false, or when volatility data
# is unavailable (network error during adaptive threshold fetch).
rebalanceThresholdBps: 100        # 1.0% (default)

# Maximum acceptable slippage between expected and actual fill price (bps).
maxSlippageBps: 100               # 1.0% (default)

# Skip rebalancing if total portfolio value is below this threshold (BRL).
# Minimum allowed: 10. Recommended: at least 2× minTradeSizeBrl.
minPortfolioValueBrl: 200

# Skip a trade if the computed rebalance amount is below this value (BRL).
# Also used as minimum when capping trades under neverExceedExemptionLimit.
minTradeSizeBrl: 20

# How often to check for rebalance opportunities (seconds).
# Each cycle costs only 1 API request (price check). 900s = 15 minutes is
# appropriate for a daily-candle strategy and keeps well within API rate limits.
pollIntervalSeconds: 900

# Minimum time between two consecutive rebalances (seconds).
# Prevents thrashing near the threshold.
minRebalanceIntervalSeconds: 7200  # 2 hours (default)


# ── Volatility-adaptive threshold ─────────────────────────────────────────────

# When true, the rebalance threshold is computed dynamically each cycle as:
#   threshold = thresholdVolatilityMultiplier × mean_absolute_daily_return_30d × 10000
# This widens the threshold in volatile markets and tightens it in calm ones.
# Falls back to rebalanceThresholdBps if volatility data cannot be fetched.
useAdaptiveThreshold: true

# How many multiples of daily volatility to use as the threshold.
# Higher value → rebalances less often. Range: 0.5–5.0.
thresholdVolatilityMultiplier: 1.5

# Rolling window for mean absolute daily return computation (days).
# Range: 7–90.
volatilityWindowDays: 30


# ── Tax compliance ─────────────────────────────────────────────────────────────

# Lei 9.250/1995 Art. 21 (domestic exchange):
#   When true, SELL_HYPE trades are capped so monthly gross SELL proceeds stay
#   ≤ R$34,650 (R$35,000 minus a 1% safety buffer). BUY trades are never capped.
#   If the remaining allowance is below minTradeSizeBrl, the SELL trade is skipped.
#
# Default: false (tracking only — no trade capping).
neverExceedExemptionLimit: false


# ── Runtime ───────────────────────────────────────────────────────────────────

# Dry-run mode: simulate rebalances without placing real orders.
# All logic runs normally; trades are logged with status DRY_RUN.
dryRun: false

# Log verbosity: error | warn | info | debug
logLevel: info


# ── Data persistence ────────────────────────────────────────────────────────────
# SQLite database for all trade history, portfolio snapshots, and tax tracking.
# Also maintains a rolling 15-day JSON backup window for recovery.

dbPath: ./data/shannonfi.db

# Number of days to keep data in JSON backup files (0 = disable JSON backup).
# After 15 days, older records are pruned from JSON but stay in SQLite.
jsonRetentionDays: 15


# ── Daily Digest Email ──────────────────────────────────────────────────────────
# Optional: Configure SMTP for daily trading digest emails at 00:30 AM BRT.
#
# RECOMMENDED: Store credentials securely in GNOME Keyring using:
#   npm run setup-smtp
#
# FALLBACK: Optionally specify credentials here (less secure, not recommended):
# smtp:
#   host: smtp.mail.yahoo.com
#   port: 587
#   secure: false
#   username: your-email@yahoo.com.br
#   password: your-app-password
#   recipientEmail: your-email@yahoo.com.br
