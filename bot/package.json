{
  "name": "@shannonfi/bot",
  "version": "1.0.0",
  "description": "Shannon's Demon rebalancing bot (Mercado Bitcoin, Binance)",
  "private": true,
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "start:once": "node dist/index.js --once",
    "dev": "ts-node src/index.ts",
    "dev:once": "ts-node src/index.ts --once",
    "setup-check": "ts-node src/scripts/setup-check.ts",
    "liquidate": "./liquidate.sh",
    "liquidate:built": "node dist/scripts/liquidate.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "scan": "ts-node -r tsconfig-paths/register src/scanner/scan.ts",
    "scan:binance": "ts-node -r tsconfig-paths/register src/scanner/scan.ts",
    "migrate": "ts-node src/scripts/migrate-json-to-db.ts",
    "reconcile": "ts-node src/scripts/reconcile-orders.ts",
    "reconcile:built": "node dist/scripts/reconcile-orders.js",
    "dashboard": "ts-node src/publishers/dashboard.ts",
    "dashboard:built": "node dist/publishers/dashboard.js"
  },
  "dependencies": {
    "axios": "^1.16.1",
    "axios-retry": "4.4.1",
    "better-sqlite3": "^11.0.0",
    "js-yaml": "^4.1.1",
    "uuid": "^14.0.0",
    "winston": "3.13.0",
    "zod": "3.23.8"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.8",
    "@types/js-yaml": "4.0.9",
    "@types/node": "20.14.2",
    "@types/uuid": "9.0.8",
    "@vitest/coverage-v8": "^1.6.1",
    "ts-node": "10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "5.4.5",
    "vitest": "^1.6.1"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
