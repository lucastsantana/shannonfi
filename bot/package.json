{
  "name": "@shannonfi/bot",
  "version": "1.0.0",
  "description": "Shannon's Demon rebalancing bot — unified adapter for Coinbase and Mercado Bitcoin",
  "private": true,
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "start:once": "node dist/index.js --once",
    "dev": "ts-node src/index.ts",
    "dev:once": "ts-node src/index.ts --once",
    "dev:report": "ts-node src/index.ts --report",
    "backtest": "ts-node src/scripts/backtest.ts",
    "setup-check": "ts-node src/scripts/setup-check.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "axios": "1.7.2",
    "axios-retry": "4.4.1",
    "bottleneck": "^2.19.5",
    "js-yaml": "4.1.0",
    "jsonwebtoken": "9.0.2",
    "uuid": "9.0.1",
    "winston": "3.13.0",
    "zod": "3.23.8"
  },
  "devDependencies": {
    "@types/js-yaml": "4.0.9",
    "@types/jsonwebtoken": "9.0.6",
    "@types/node": "20.14.2",
    "@types/uuid": "9.0.8",
    "@vitest/coverage-v8": "1.6.0",
    "ts-node": "10.9.2",
    "typescript": "5.4.5",
    "vitest": "1.6.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
