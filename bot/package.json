{
  "name": "@shannonfi/bot",
  "version": "1.0.0",
  "description": "Shannon's Demon rebalancing bot for Mercado Bitcoin (SOL-BRL)",
  "private": true,
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "start:once": "node dist/index.js --once",
    "dev": "ts-node src/index.ts",
    "dev:once": "ts-node src/index.ts --once",
    "dev:report": "ts-node src/index.ts --report",
    "report": "ts-node src/scripts/monthly-report.ts",
    "report:built": "node dist/scripts/monthly-report.js",
    "daily-digest": "ts-node src/scripts/daily-digest.ts",
    "daily-digest:built": "node dist/scripts/daily-digest.js",
    "setup-check": "ts-node src/scripts/setup-check.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "axios": "^1.16.1",
    "axios-retry": "4.4.1",
    "better-sqlite3": "^11.0.0",
    "js-yaml": "^4.1.1",
    "nodemailer": "^6.10.1",
    "uuid": "^14.0.0",
    "winston": "3.13.0",
    "zod": "3.23.8"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.8",
    "@types/js-yaml": "4.0.9",
    "@types/node": "20.14.2",
    "@types/nodemailer": "^6.4.23",
    "@types/uuid": "9.0.8",
    "@vitest/coverage-v8": "^1.6.1",
    "ts-node": "10.9.2",
    "typescript": "5.4.5",
    "vitest": "^1.6.1"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
