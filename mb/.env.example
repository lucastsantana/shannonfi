# Mercado Bitcoin API credentials
# Generate at: https://www.mercadobitcoin.com.br/api
MB_CLIENT_ID=your-client-id
MB_CLIENT_SECRET=your-client-secret

# Optional: override API base URL (for local testing)
# MB_API_BASE_URL=https://api.mercadobitcoin.net/api/v4

# Trading parameters
DRY_RUN=true                          # Set to false for live trading
REBALANCE_THRESHOLD_BPS=100           # 1% drift threshold (overridden by adaptive if enabled)
MAX_SLIPPAGE_BPS=100                  # Max acceptable slippage per trade
MIN_PORTFOLIO_VALUE_BRL=200           # Skip if portfolio below R$200
MIN_TRADE_SIZE_BRL=20                 # Skip trade if BRL amount below R$20
POLL_INTERVAL_SECONDS=300             # Check every 5 minutes
MIN_REBALANCE_INTERVAL_SECONDS=7200   # Min 2 hours between rebalances

# Volatility-adaptive threshold (SOL-BRL mean absolute daily return)
USE_ADAPTIVE_THRESHOLD=true
THRESHOLD_VOLATILITY_MULTIPLIER=1.5
VOLATILITY_WINDOW_DAYS=30

# Brazilian tax compliance
# When true, SELL_SOL trades are capped so cumulative monthly sales stay
# under R$34,650 (R$35,000 - R$350 safety buffer), preserving the
# Lei 9.250/1995 Art. 21 monthly exemption for domestic exchange trades.
# BUY_SOL purchases do NOT count toward this limit.
NEVER_EXCEED_EXEMPTION_LIMIT=false

# Log level: error | warn | info | debug
LOG_LEVEL=info

# Data file paths (relative to mb/ directory)
TRADE_HISTORY_PATH=./data/trade_history.json
PORTFOLIO_SNAPSHOTS_PATH=./data/portfolio_snapshots.json
COST_BASIS_PATH=./data/cost_basis.json
TAX_EVENTS_PATH=./data/tax_events.json
