{
  "name": "@shannonfi/mb",
  "version": "1.0.0",
  "description": "Shannon's Demon rebalancing bot for Mercado Bitcoin (BRL-native)",
  "private": true,
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "axios": "1.7.2",
    "axios-retry": "4.4.1",
    "uuid": "9.0.1",
    "winston": "3.13.0",
    "dotenv": "16.4.5",
    "zod": "3.23.8"
  },
  "devDependencies": {
    "@types/uuid": "9.0.8",
    "@types/node": "20.14.2",
    "typescript": "5.4.5",
    "ts-node": "10.9.2",
    "vitest": "1.6.0",
    "@vitest/coverage-v8": "1.6.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
