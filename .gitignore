# Build artifacts
/target/
*.so
*.dylib
*.dll
*.rlib
*.rmeta

# Cargo lock file (for binary crates, but okay to commit for libraries)
Cargo.lock

# Node modules and build
node_modules/
dist/
build/
*.log

# IDEs
.idea/
.vscode/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Environment
.env
.env.local
.env.*.local

# Data files (never commit live trading data)
bot/data/*.db
bot/data/*.db-wal
bot/data/*.db-shm
bot/data/*.json

# Report artifacts (PDF and LaTeX build artifacts, keep .tex source)
bot/data/reports/*.pdf
bot/data/reports/*.aux
bot/data/reports/*.log
bot/data/reports/*.nav
bot/data/reports/*.out
bot/data/reports/*.snm
bot/data/reports/*.toc
bot/data/reports/*.fls
bot/data/reports/*.fdb_latexmk
data/reports/*.pdf
data/reports/*.aux
data/reports/*.log
data/reports/*.nav
data/reports/*.out
data/reports/*.snm
data/reports/*.toc
data/reports/*.fls
data/reports/*.fdb_latexmk

# reporting/ should never hold live data — running its scripts from the wrong
# cwd (anything but bot/) has accidentally created stray DB/PDF files here before.
reporting/data/

# Stray SQLite files from in-memory test URIs
bot/:memory:*

# GitHub Pages build artifact (generated by dashboard workflow)
public/

# Anchor
.anchor/
**/.anchor/
idl/
