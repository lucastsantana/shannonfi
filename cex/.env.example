# ─── Coinbase CDP API Credentials ──────────────────────────────────────────
# Obtained from: https://portal.cdp.coinbase.com/ → API Keys
# Key Name format: "organizations/<org-id>/apiKeys/<key-id>"
COINBASE_API_KEY_NAME=organizations/abc123/apiKeys/def456

# EC private key in PEM format (ES256). Use \n for literal newlines in .env.
# Alternatively, set COINBASE_API_KEY_PEM_FILE to point to a file path.
COINBASE_API_KEY_PRIVATE_KEY="-----BEGIN EC PRIVATE KEY-----\nMHQCAQ...base64...\n-----END EC PRIVATE KEY-----\n"
# COINBASE_API_KEY_PEM_FILE=/run/secrets/coinbase_key.pem

# ─── Strategy Parameters ────────────────────────────────────────────────────
# Drift threshold before a rebalance is triggered (basis points, default: 100 = 1%)
REBALANCE_THRESHOLD_BPS=100

# Maximum acceptable slippage (basis points, default: 100 = 1%)
MAX_SLIPPAGE_BPS=100

# Minimum portfolio value in USD to allow trading
MIN_PORTFOLIO_VALUE_USD=50

# Minimum trade size in USD (Coinbase minimum is ~$1; set higher to cover fees)
MIN_TRADE_SIZE_USD=5

# ─── Polling & Timing ───────────────────────────────────────────────────────
# How often the bot polls for drift, in seconds (default: 300 = 5 minutes)
POLL_INTERVAL_SECONDS=300

# Minimum seconds between rebalances even if drift is above threshold (default: 7200 = 2 hours)
# Prevents thrashing when price oscillates near the threshold
MIN_REBALANCE_INTERVAL_SECONDS=7200

# ─── Operation Mode ─────────────────────────────────────────────────────────
# Set to "true" to simulate without placing real orders
DRY_RUN=false

# Log level: error | warn | info | debug
LOG_LEVEL=info

# ─── Persistence ────────────────────────────────────────────────────────────
TRADE_HISTORY_PATH=./data/trade_history.json

# ─── Coinbase API Base URL (override for testing) ───────────────────────────
# COINBASE_API_BASE_URL=https://api.coinbase.com
