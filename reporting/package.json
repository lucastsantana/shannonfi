{
  "name": "@shannonfi/reporting",
  "version": "1.0.0",
  "description": "Report generation library for Shannon's Demon - generates Markdown reports and a dark-themed investor PDF report (HTML + Playwright), with Claude-generated commentary",
  "private": true,
  "main": "dist/report-builder.js",
  "exports": {
    ".": {
      "import": "./dist/report-builder.js",
      "types": "./dist/report-builder.d.ts"
    },
    "./types": {
      "import": "./dist/report-types.js",
      "types": "./dist/report-types.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "report": "ts-node src/monthly-report.ts",
    "report:pdf": "ts-node src/pdf-report.ts",
    "playwright:install": "playwright install --with-deps chromium"
  },
  "dependencies": {
    "playwright": "^1.48.0"
  },
  "devDependencies": {
    "typescript": "5.4.5",
    "ts-node": "10.9.2",
    "@types/node": "20.14.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
